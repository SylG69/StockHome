[MAIN]
# Exclut les migrations Alembic : fichiers générés automatiquement, jamais
# édités à la main, pas pertinents à linter.
ignore-paths=^backend/alembic/.*$

[MESSAGES CONTROL]
disable=missing-module-docstring,
        missing-function-docstring,
        missing-class-docstring,
        raw-checker-failed,
        bad-inline-option,
        locally-disabled,
        file-ignored,
        suppressed-message,
        useless-suppression,
        deprecated-pragma,
        use-symbolic-message-instead,
        use-implicit-booleaness-not-comparison-to-string,
        use-implicit-booleaness-not-comparison-to-zero

[FORMAT]
# 130 plutôt que le défaut de 100 : plus adapté au style du projet
# (lignes descriptives avec docstrings/commentaires en fin de ligne).
max-line-length=130

[REPORTS]
score=yes
# Fichier lu par docker-compose (`docker compose up`). Copiez-le en `.env`
# à la racine du dépôt et adaptez les valeurs avant de lancer les conteneurs.

# Base de données PostgreSQL (conteneur "db")
POSTGRES_DB=stockhome
POSTGRES_USER=stockhome
POSTGRES_PASSWORD=changeme

# Secret de signature des tokens JWT (générez une valeur aléatoire longue,
# ex: openssl rand -hex 32)
JWT_SECRET=change-moi-en-une-longue-chaine-aleatoire

# Origines autorisées en CORS, séparées par des virgules (ou * pour tout
# autoriser — à réserver à un usage local/PC perso, pas en exposition VPS)
CORS_ORIGINS=*

# Port exposé sur l'hôte pour accéder à l'application (frontend + API)
APP_PORT=8000
